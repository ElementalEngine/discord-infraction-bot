{
  "name": "lady-justice-bot",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "dev:deploy": "NODE_ENV=development tsx src/deploy.ts",
    "build": "tsc",
    "start": "NODE_ENV=production node --enable-source-maps dist/index.js",
    "deploy": "NODE_ENV=production node --enable-source-maps dist/deploy.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "verify": "npm run typecheck && npm run build && npm run lint"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "undici": "6.27.0"
  }
}
